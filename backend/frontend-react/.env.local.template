# ZapPay Frontend React Configuration
# Copy this file to .env.local and update values

# ===========================================
# API Endpoints
# ===========================================

# For local development (default if not set)
# VITE_CUSTOMER_API=http://localhost:8000
# VITE_PUMP_API=http://localhost:8001

# For ngrok tunnels (copy URLs from ngrok output)
# Customer API (from: ngrok http 8000)
VITE_CUSTOMER_API=https://PASTE-YOUR-CUSTOMER-API-URL-HERE.ngrok-free.app

# Pump API (from: ngrok http 8001)
VITE_PUMP_API=https://PASTE-YOUR-PUMP-API-URL-HERE.ngrok-free.app

# ===========================================
# Production URLs (update for deployment)
# ===========================================
# VITE_CUSTOMER_API=https://api.zappay.in
# VITE_PUMP_API=https://pump-api.zappay.in

# ===========================================
# Feature Flags (optional)
# ===========================================
# VITE_ENABLE_MOCK=false
# VITE_DEBUG=false
