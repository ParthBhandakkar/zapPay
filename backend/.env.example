# ZapPay Backend — Environment Configuration
# Copy to .env and fill in your values

# ── Environment ────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_VERSION=1.0.0

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────
# Example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=3

# ── Redis (Upstash) ────────────────────────────────────────────────────
# Example:
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_REGION.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=5

# ── Security (REQUIRED) ────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.onrender.com

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Payment Gateways (optional) ────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── QR Encryption (optional) ───────────────────────────────────────────
# QR_ENCRYPTION_KEY=

# ── SMS (optional) ─────────────────────────────────────────────────────
# SMS_API_KEY=
# SMS_SENDER_ID=ZAPPAY
# SMS_PROVIDER=fast2sms
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Email (optional) ───────────────────────────────────────────────────
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ── Monitoring (optional) ──────────────────────────────────────────────
# SENTRY_DSN=
